# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL / SUPABASE_ANON_KEY: read by the Secrets Gradle Plugin into
# BuildConfig. Copy this file to ".env" at the REPO ROOT (not inside app/)
# and fill in real values there. Never commit the real .env file.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key
